+const oauthRefreshLocks = new Map<
+  string,
+  Promise<{ refresh: string; access: string; expires: number }>
+>()
+
+async function refreshOAuthAccess(
+  auth: { refresh?: string },
+  client: unknown,
+): Promise<{ refresh: string; access: string; expires: number }> {
+  const refreshKey =
+    typeof auth.refresh === 'string' && auth.refresh
+      ? auth.refresh
+      : '__missing_refresh__'
+  const existing = oauthRefreshLocks.get(refreshKey)
+  if (existing) {
+    return await existing
+  }
+
+  const promise = (async () => {
+    const maxRetries = 2
+    const baseDelayMs = 500
+
+    for (let attempt = 0; attempt <= maxRetries; attempt++) {
+      try {
+        if (attempt > 0) {
+          const delay = baseDelayMs * 2 ** (attempt - 1)
+          await new Promise((resolve) => setTimeout(resolve, delay))
+        }
+
+        const response = await fetch(TOKEN_URL, {
+          method: 'POST',
+          headers: {
+            'Content-Type': 'application/json',
+            Accept: 'application/json, text/plain, */*',
+            'User-Agent': 'axios/1.13.6',
+          },
+          body: JSON.stringify({
+            grant_type: 'refresh_token',
+            refresh_token: auth.refresh,
+            client_id: CLIENT_ID,
+          }),
+        })
+
+        if (!response.ok) {
+          if (response.status >= 500 && attempt < maxRetries) {
+            await response.body?.cancel()
+            continue
+          }
+
+          let detail = ''
+          try {
+            detail = await response.text()
+          } catch {
+            detail = ''
+          }
+
+          const suffix = detail ? `: ${detail}` : ''
+          throw new Error(`Token refresh failed: ${response.status}${suffix}`)
+        }
+
+        const json = (await response.json()) as {
+          refresh_token: string
+          access_token: string
+          expires_in: number
+        }
+
+        const nextAuth = {
+          refresh: json.refresh_token,
+          access: json.access_token,
+          expires: Date.now() + json.expires_in * 1000,
+        }
+
+        await (client as any).auth.set({
+          path: {
+            id: 'anthropic',
+          },
+          body: {
+            type: 'oauth',
+            refresh: nextAuth.refresh,
+            access: nextAuth.access,
+            expires: nextAuth.expires,
+          },
+        })
+
+        return nextAuth
+      } catch (error) {
+        const isNetworkError =
+          error instanceof Error &&
+          (error.message.includes('fetch failed') ||
+            ('code' in error &&
+              (error.code === 'ECONNRESET' ||
+                error.code === 'ECONNREFUSED' ||
+                error.code === 'ETIMEDOUT' ||
+                error.code === 'UND_ERR_CONNECT_TIMEOUT')))
+
+        if (attempt < maxRetries && isNetworkError) {
+          continue
+        }
+
+        throw error
+      }
+    }
+
+    throw new Error('Token refresh failed: retry loop exhausted')
+  })()
+
+  oauthRefreshLocks.set(refreshKey, promise)
+  try {
+    return await promise
+  } finally {
+    if (oauthRefreshLocks.get(refreshKey) === promise) {
+      oauthRefreshLocks.delete(refreshKey)
+    }
+  }
+}
 
